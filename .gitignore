# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/

# Pipeline artifacts (generated, not source)
/output/
/orchestrator/output/
*.vp3
*.VP3
*.dst
*.emb

# Orchestrator drop zone: keep the folder, ignore whatever photo is dropped in it
/input/*
!/input/.gitkeep

# Pairs drop zone: keep the README, ignore the (large, transient) dropped pairs.
# Ingested pairs are filed under <category>/pairs/ and tracked there instead.
/pairs-inbox/*
!/pairs-inbox/README.md

# Falahi category: track its knowledge doc + any ingested pairs/, but ignore the loose
# large working SVGs dropped at the dir root (VP3s are already ignored globally above).
/falahi/*.svg

# Vendored Ink-Stitch portable bundle (~185MB, downloaded, not source)
/vendor/

# Wilcom official manuals (~300MB of PDFs; distilled rules live in
# wilcom-manual-rules.md, which IS tracked). Keep the source PDFs local.
/wilcom-manual/
*.rar

# Samples can be large / proprietary — track deliberately, not by default
/samples/*
!/samples/.gitkeep

# OS / editor
.DS_Store
*.swp

# Root test images (inputs, copied into samples/ when used)
/*.png
